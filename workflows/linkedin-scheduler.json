    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{{\n  \"success\": true,\n  \"message\": \"Post processed\",\n  \"postId\": $json.postId,\n  \"status\": $json.status,\n  \"linkedinPostId\": $json.linkedinPostId || null,\n  \"attempts\": $json.attempts\n}}}"
      },
      "id": "webhook-response",
      "name": "Webhook Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [3200, 200]
    },
    {
      "parameters": {
        "jsCode": "// Format log entry\nconst item = $input.first().json;\n\nreturn [{\n  json: {\n    postId: item.postId || '',\n    linkedinPostId: item.linkedinPostId || '',\n    platform: item.platform || 'linkedin',\n    content: (item.content || '').replace(/,/g, ';').replace(/\\n/g, ' ').substring(0, 200),\n    scheduledTime: item.scheduledTime || '',\n    postedAt: item.postedAt || '',\n    failedAt: item.failedAt || '',\n    status: item.status || '',\n    attempts: item.attempts || 0,\n    errorMessage: (item.error?.message || '').replace(/,/g, ';'),\n    errorCode: item.error?.code || ''\n  }\n}];"
      },
      "id": "format-log-entry",
      "name": "Format Log Entry",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2800, 200]
    },
